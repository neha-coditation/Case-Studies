#!/usr/bin/env python3
"""
sync_new_html_to_webflow.py

Place this file at: scripts/sync_new_html_to_webflow.py

Run by the "Sync new case studies to Webflow" GitHub Actions workflow on
every push to main. Finds .html files that were newly ADDED in the push
(not modified, not deleted) and creates a live Webflow CMS Collection Item
for each one.

Required environment variables (set as GitHub Actions secrets):
    WEBFLOW_API_TOKEN      Webflow API token with CMS: read/write scope
    WEBFLOW_COLLECTION_ID  Target Collection ID (e.g. the "Case Studies" collection)
    WEBFLOW_SITE_ID        Site ID (used for the safety-net publish call)

Optional environment variables:
    WEBFLOW_LINK_FIELD_SLUG  Field slug for the "live page URL" field on the
                              collection. Defaults to "live-url". Change this
                              (as a GitHub Actions *variable*, not secret) to
                              match your collection's actual field slug.
    PAGES_BASE_URL           Base URL the site is published to. Defaults to
                              https://neha-coditation.github.io/Case-Studies
    GITHUB_BEFORE_SHA / GITHUB_AFTER_SHA
                              Commit range to diff. In the workflow these are
                              populated from github.event.before / github.sha.
"""

import os
import re
import subprocess
import sys
from html.parser import HTMLParser

WEBFLOW_API_BASE = "https://api.webflow.com/v2"
EMPTY_TREE_SHA = "4b825dc642cb6eb9a060e54bf8d69288fbee4904"  # git's empty tree object


class TitleExtractor(HTMLParser):
    """Pulls the text out of the first <title> tag, if present."""

    def __init__(self):
        super().__init__()
        self.in_title = False
        self.title = None

    def handle_starttag(self, tag, attrs):
        if tag.lower() == "title":
            self.in_title = True

    def handle_endtag(self, tag):
        if tag.lower() == "title":
            self.in_title = False

    def handle_data(self, data):
        if self.in_title and data.strip():
            self.title = data.strip()


def run(cmd):
    result = subprocess.run(cmd, capture_output=True, text=True, check=True)
    return result.stdout


def get_newly_added_html_files(before_sha, after_sha):
    """Return repo-relative paths of .html files added in this push."""
    if not before_sha or before_sha == "0" * 40:
        # First push to a new branch, or before-SHA unavailable: diff
        # against git's empty tree so every file in the push looks "added".
        before_sha = EMPTY_TREE_SHA

    diff_output = run(
        ["git", "diff", "--name-status", "--diff-filter=A", before_sha, after_sha]
    )

    added_files = []
    for line in diff_output.splitlines():
        if not line.strip():
            continue
        status, path = line.split("\t", 1)
        if path.lower().endswith(".html"):
            added_files.append(path)
    return added_files


def slugify(text):
    text = text.lower().strip()
    text = re.sub(r"[^a-z0-9]+", "-", text)
    return text.strip("-")


def build_name_and_slug(file_path):
    filename = os.path.basename(file_path)
    stem = os.path.splitext(filename)[0]
    slug = slugify(stem)

    name = None
    try:
        with open(file_path, "r", encoding="utf-8", errors="ignore") as f:
            parser = TitleExtractor()
            parser.feed(f.read())
            if parser.title:
                name = parser.title
    except OSError:
        pass

    if not name:
        name = stem.replace("-", " ").replace("_", " ").title()

    return name, slug


def create_webflow_item(session, collection_id, name, slug, link_url, link_field_slug):
    field_data = {
        "name": name,
        "slug": slug,
        link_field_slug: link_url,
    }

    response = session.post(
        f"{WEBFLOW_API_BASE}/collections/{collection_id}/items/live",
        json={"fieldData": field_data, "isArchived": False, "isDraft": False},
    )

    if response.status_code == 409:
        print(f"  Skipped '{slug}': an item with this slug already exists.")
        return None

    if not response.ok:
        print(f"  ERROR creating item for '{slug}': {response.status_code} {response.text}")
        return None

    item = response.json()
    print(f"  Created item '{name}' (slug: {slug}, id: {item.get('id')})")
    return item


def publish_site(session, site_id):
    response = session.post(f"{WEBFLOW_API_BASE}/sites/{site_id}/publish", json={"publishToWebflowSubdomain": True})
    if not response.ok:
        print(f"  WARNING: site publish call failed: {response.status_code} {response.text}")
    else:
        print("  Site publish triggered.")


def main():
    api_token = os.environ.get("WEBFLOW_API_TOKEN")
    collection_id = os.environ.get("WEBFLOW_COLLECTION_ID")
    site_id = os.environ.get("WEBFLOW_SITE_ID")
    link_field_slug = os.environ.get("WEBFLOW_LINK_FIELD_SLUG", "live-url")
    pages_base_url = os.environ.get(
        "PAGES_BASE_URL", "https://neha-coditation.github.io/Case-Studies"
    ).rstrip("/")
    before_sha = os.environ.get("GITHUB_BEFORE_SHA", "")
    after_sha = os.environ.get("GITHUB_AFTER_SHA", "HEAD")

    missing = [
        name
        for name, val in [
            ("WEBFLOW_API_TOKEN", api_token),
            ("WEBFLOW_COLLECTION_ID", collection_id),
            ("WEBFLOW_SITE_ID", site_id),
        ]
        if not val
    ]
    if missing:
        print(f"Missing required environment variables: {', '.join(missing)}")
        sys.exit(1)

    new_files = get_newly_added_html_files(before_sha, after_sha)
    if not new_files:
        print("No newly added .html files in this push. Nothing to do.")
        return

    print(f"Found {len(new_files)} new .html file(s): {new_files}")

    import requests

    session = requests.Session()
    session.headers.update(
        {
            "Authorization": f"Bearer {api_token}",
            "accept": "application/json",
            "content-type": "application/json",
        }
    )

    created_any = False
    for file_path in new_files:
        name, slug = build_name_and_slug(file_path)
        link_url = f"{pages_base_url}/{file_path}"
        print(f"Processing {file_path} -> name='{name}', slug='{slug}', url='{link_url}'")
        item = create_webflow_item(session, collection_id, name, slug, link_url, link_field_slug)
        created_any = created_any or bool(item)

    if created_any:
        publish_site(session, site_id)


if __name__ == "__main__":
    main()
